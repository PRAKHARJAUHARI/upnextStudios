# ─────────────────────────────────────────────────────────────
# UPNEXT AGENCY — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# Formbricks Webhook Secret
# Get this from: Formbricks Dashboard → Settings → Webhooks → Secret
FORMBRICKS_WEBHOOK_SECRET=your_webhook_secret_here

# Formbricks Public Keys (safe to expose — used in browser)
NEXT_PUBLIC_FORMBRICKS_ENVIRONMENT_ID=your_environment_id_here
NEXT_PUBLIC_FORMBRICKS_SURVEY_ID=cmmfepybxbia9um01eqhrc9ds

# SMTP (Hostinger email, for webhook email notifications)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=Upnext.sociomedia@gmail.com
SMTP_PASS=your_email_password_here

# Database (optional — if using Hostinger MySQL)
DATABASE_URL=mysql://user:password@localhost:3306/upnext_db

# Site URL
NEXT_PUBLIC_SITE_URL=https://upnextagency.com
